<section id="contact" class="homepage-section contact-section" aria-labelledby="contact-title">
  <div class="section-header">
    <p class="section-kicker">START A CONVERSATION</p>
    <h2 id="contact-title" class="section-title">Tell me what you need to build, improve, or unblock</h2>
    <p class="section-summary">
      Share your product idea, technical challenge, or delivery problem. I will reply with a practical next step and whether I am the right fit.
    </p>
  </div>

  <div class="contact-layout">
    <form
      class="contact-form"
      action="{{ metadata.formspree_endpoint }}"
      method="POST"
      data-contact-form
    >
      <div class="contact-feedback" data-contact-feedback aria-live="polite"></div>

      <div class="form-row">
        <label class="form-field">
          <span>First name</span>
          <input type="text" class="form-control" name="first_name" required placeholder="First name">
        </label>
        <label class="form-field">
          <span>Last name</span>
          <input type="text" class="form-control" name="last_name" required placeholder="Last name">
        </label>
      </div>

      <div class="form-row">
        <label class="form-field">
          <span>Email</span>
          <input type="email" class="form-control" name="email" required placeholder="name@example.com">
        </label>
        <label class="form-field">
          <span>Phone</span>
          <input type="text" class="form-control" name="phone" placeholder="+977 98XXXXXXXX">
        </label>
      </div>

      <label class="form-field">
        <span>Project details</span>
        <textarea class="form-control" name="message" required placeholder="Tell me about the product, timeline, and what is blocking progress right now."></textarea>
      </label>

      <input type="hidden" name="_subject" value="New homepage enquiry from Ompirit" />
      <input type="hidden" name="_captcha" value="false" />

      <div class="contact-actions">
        <button type="submit" class="form-tag">Send enquiry</button>
        <p class="contact-note">Prefer email or phone? You can reach me directly using the details on the right.</p>
      </div>
    </form>

    <aside class="contact-panel">
      <div class="contact-panel-block">
        <p class="contact-label">Contact</p>
        <a href="tel:+9779847259410" class="contact-link">(+977) 9847259410</a>
        <a href="mailto:support@ompirit.com" class="contact-link">support@ompirit.com</a>
      </div>

      <div class="contact-panel-block">
        <p class="contact-label">Common reasons to reach out</p>
        <ul class="contact-reasons">
          <li>You need senior help to build an MVP, internal tool, or product feature.</li>
          <li>You want support with Rails development, DevOps, debugging, or system improvements.</li>
          <li>You need a technical partner who can communicate clearly and work hands-on.</li>
        </ul>
      </div>

      <div class="contact-panel-block">
        <p class="contact-label">Profiles</p>
        <div class="contact-socials">
          <a href="https://www.linkedin.com/in/sarbada-nanda-jaiswal-6a461aba/" aria-label="Sarbada on LinkedIn"><img src="{{ '/images/Linkedin1234.png' | relative_url }}" class="Component" alt="LinkedIn logo" /></a>
        </div>
      </div>
    </aside>
  </div>
</section>
